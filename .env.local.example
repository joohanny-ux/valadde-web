# Next.js
# .env.local 로 복사 후 값 채우기

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 클라이언트 Auth용 (회원가입/로그인) - Supabase 대시보드 API에서 anon key 복사
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# 관리자 로그인 비밀번호 (필수)
ADMIN_PASSWORD=원하는비밀번호

# 상세페이지 에이전트 (무료 스택)
GOOGLE_AI_API_KEY=   # Google AI Studio에서 발급 (Gemini)
GEMINI_MODEL=        # 선택: 기본 gemini-2.5-flash. 404시 gemini-2.5-flash-preview-05-20 등 시도
SERPER_API_KEY=      # 선택: serper.dev 가입 후 발급 (2,500검색/월 무료)
